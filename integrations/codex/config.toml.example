# Copy to .codex/config.toml in a trusted project, or merge into ~/.codex/config.toml.
# Docs: https://developers.openai.com/codex/mcp

[mcp_servers.milknado]
command = "uv"
args = ["run", "milknado-mcp"]
cwd = "." # set to your workspace root, or omit and use MILKNADO_PROJECT_ROOT

[mcp_servers.milknado.env]
MILKNADO_PROJECT_ROOT = "."
