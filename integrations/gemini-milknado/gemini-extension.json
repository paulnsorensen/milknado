{
  "name": "milknado",
  "version": "0.1.0",
  "mcpServers": {
    "milknado": {
      "command": "uv",
      "args": ["run", "milknado-mcp"],
      "env": {
        "MILKNADO_PROJECT_ROOT": "${workspacePath}"
      }
    },
    "tilth": {
      "command": "tilth",
      "args": ["--mcp"]
    }
  }
}
